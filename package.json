{
  "name": "res-prolog",
  "version": "0.1.0",
  "description": "A Prolog-inspired logical programming framework in ReScript, type-driven (no string interpolation).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "res:build": "rescript build",
    "res:clean": "rescript clean",
    "res:watch": "rescript build -w",
    "build": "pnpm res:build && vite build",
    "dev": "pnpm res:build && vite",
    "preview": "vite preview",
    "test": "pnpm res:build && node lib/es6/tests/Tests.res.mjs",
    "example": "pnpm res:build && node lib/es6/examples/Family.res.mjs"
  },
  "keywords": [
    "rescript",
    "prolog",
    "logic",
    "unification"
  ],
  "devDependencies": {
    "@rescript/runtime": "^12.2.0",
    "rescript": "12.2.0",
    "vite": "^8.0.11"
  },
  "packageManager": "pnpm@9.15.0"
}
